# Keep recommended extensions shareable, but ignore other local workspace files.
.vscode/*
!.vscode/extensions.json

# Firmware/build outputs
*.bin
*.elf
*.map
*.hex
*.uf2

# Flutter/Dart generated files
app/**/.dart_tool/
