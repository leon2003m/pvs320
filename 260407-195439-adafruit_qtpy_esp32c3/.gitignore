app/**/.packages
app/**/pubspec.lock
app/**/android/.gradle/
app/**/android/local.properties
app/**/ios/Flutter/ephemeral/
app/**/macos/Flutter/ephemeral/
app/**/linux/flutter/ephemeral/
app/**/windows/flutter/ephemeral/

# Local secret/config overrides
platformio.local.ini
secrets.h
*secret*
*secrets*

# OS/editor noise
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp
