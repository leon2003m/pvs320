#include <WiFi.h>
#include <ArduinoOTA.h>
#include <HardwareSerial.h>
#include <AiEsp32RotaryEncoder.h>
#include <Preferences.h>

// ---------- WiFi credentials ----------
const char* ssid     = "XXXXXXXXXXXXXXXX";
const char* password = "XXXXXXXXXXXXXXXX";

// ---------- Pins ----------
#define ROTARY_A_PIN    0
#define ROTARY_B_PIN    1
#define ROTARY_SW_PIN   7
#define THUMB_BUTTON    6
#define LED_BLUE        8
#define RX_PIN          20
#define TX_PIN          21

#define LED_OFF HIGH
#define LED_ON  LOW

// ---------- P6-UC Commands ----------
#define CMD_CALIBRATE   0x26
#define CMD_SAVE        0x29
#define CMD_ADJUST      0x2A
#define CMD_ZOOM        0x2B
#define CMD_PALETTE     0x2D

// ---------- State ----------
Preferences preferences;
int brightness      = 64;
int contrastIdx     = 1;    // Starts at 64 (Index 1) to match stock neutral
int contrastSteps[] = {32, 64, 96, 128, 160, 192, 224, 255};
int palette         = 1;    // White Hot
int zoomVal         = 10;   // 1.0x
bool autoCalEnabled = false;
bool wifiActive     = false;

// Timers & Flags
unsigned long thumbDownTime = 0;
unsigned long encDownTime = 0;
unsigned long lastBtnPressTime = 0;
unsigned long thumbActionCooldown = 0;
bool thumbWasInteracted = false;
bool b5s = false;
bool b10s = false;
bool lastEncState = false;

AiEsp32RotaryEncoder rotaryEncoder = AiEsp32RotaryEncoder(ROTARY_A_PIN, ROTARY_B_PIN, ROTARY_SW_PIN, -1, 4);

void IRAM_ATTR readEncoderISR() {
  rotaryEncoder.readEncoder_ISR();
}

void sendPacket(uint8_t c1, uint8_t c2, uint8_t d0 = 0, uint8_t d1 = 0) {
  uint8_t pkt[13] = {0x55, c1, c2, d0, d1, 0, 0, 0, 0, 0, 0, 0, 0xAA};
  uint8_t cs = 0;
  for (int i = 0; i < 11; i++) cs += pkt[i];
  pkt[11] = cs;
  Serial1.write(pkt, 13);
}

// --- Dead Pixel Correction Routine ---
void runDPC() {
  sendPacket(CMD_CALIBRATE, 0x02); // Start DPC
  // Visual feedback & Safety delay for camera processing (3 seconds)
  for(int i=0; i<15; i++) {
    digitalWrite(LED_BLUE, LED_ON);  delay(100);
    digitalWrite(LED_BLUE, LED_OFF); delay(100);
  }
  sendPacket(CMD_CALIBRATE, 0x03); // End DPC
  delay(150);
  sendPacket(CMD_SAVE, 0x00);     // Permanent Save to Camera Core

  // Finish Notification
  for(int i=0; i<3; i++) {
    digitalWrite(LED_BLUE, LED_ON); delay(300); digitalWrite(LED_BLUE, LED_OFF); delay(200);
  }
}

void setup() {
  Serial.begin(115200);
  Serial1.begin(115200, SERIAL_8N1, RX_PIN, TX_PIN);

  // Load AutoCal state from ESP32 internal flash
  preferences.begin("p6-settings", false);
  autoCalEnabled = preferences.getBool("autocal", false);

  pinMode(ROTARY_A_PIN,  INPUT_PULLUP);
  pinMode(ROTARY_B_PIN,  INPUT_PULLUP);
  pinMode(ROTARY_SW_PIN, INPUT_PULLUP);
  pinMode(THUMB_BUTTON,  INPUT_PULLUP);
  pinMode(LED_BLUE,      OUTPUT);
  digitalWrite(LED_BLUE, LED_OFF);

  rotaryEncoder.begin();
  rotaryEncoder.setup(readEncoderISR);
  rotaryEncoder.setBoundaries(-100000, 100000, false);
  rotaryEncoder.setEncoderValue(0);

  // Wait for camera hardware boot
  delay(5500);

  // --- STAGGERED STARTUP SYNC (v8.0) ---
  // Commands are spaced by 150ms to ensure the camera registers all of them.
  sendPacket(CMD_CALIBRATE, 0x01, autoCalEnabled ? 0x01 : 0x00);
  delay(150);
  sendPacket(CMD_PALETTE, 0x01);     // Switch to White Hot
  delay(150);
  sendPacket(CMD_ADJUST, 0x02, 64);  // Match stock contrast

  Serial.println("v8.0 Ready: White Hot Active, AutoCal=" + String(autoCalEnabled));
}

void loop() {
  unsigned long now = millis();

  // -------- WiFi & LED Management --------
  if (wifiActive) {
    ArduinoOTA.handle();
    if (WiFi.status() == WL_CONNECTED) {
      digitalWrite(LED_BLUE, LED_ON);
    } else {
      digitalWrite(LED_BLUE, (now % 500 < 250) ? LED_ON : LED_OFF); // Connecting blink
    }
  } else {
    digitalWrite(LED_BLUE, LED_OFF);
  }

  bool thumbPressed = (digitalRead(THUMB_BUTTON) == LOW);
  bool encPressed   = (digitalRead(ROTARY_SW_PIN) == LOW);
  int delta = rotaryEncoder.encoderChanged();

  // -------- 1. ROTATION (Zoom or Brightness) --------
  if (delta != 0) {
    if (thumbPressed) {
      thumbWasInteracted = true;
      brightness = constrain(brightness + delta, 0, 128);
      sendPacket(CMD_ADJUST, 0x01, (uint8_t)brightness);
    } else {
      zoomVal = constrain(zoomVal + delta, 10, 40);
      sendPacket(CMD_ZOOM, 0x00, (uint8_t)zoomVal);
    }
  }

  // -------- 2. ENCODER BUTTON (Contrast / Palette / DPC) --------
  if (encPressed) {
    if (encDownTime == 0) encDownTime = now;
    // Trigger DPC: Hold Thumb + Hold Encoder for 3 seconds
    if (thumbPressed && (now - encDownTime > 3000)) {
      thumbWasInteracted = true;
      runDPC();
      encDownTime = 0;
    }
  }
  else {
    if (encDownTime > 0) {
      unsigned long hold = now - encDownTime;
      if (hold < 2000) { // Standard click logic
        if (thumbPressed) {
          thumbWasInteracted = true;
          contrastIdx = (contrastIdx + 1) % 8;
          sendPacket(CMD_ADJUST, 0x02, (uint8_t)contrastSteps[contrastIdx]);
        } else if (now - lastBtnPressTime > 250) {
          palette = (palette + 1) % 6;
          sendPacket(CMD_PALETTE, (uint8_t)palette);
        }
      }
      encDownTime = 0;
      lastBtnPressTime = now;
    }
  }

  // -------- 3. THUMB BUTTON (NUC / Wifi / AutoCal Toggle) --------
  if (thumbPressed) {
    if (thumbDownTime == 0 && (now - thumbActionCooldown > 150)) {
      thumbDownTime = now;
      thumbWasInteracted = false;
      b5s = false; b10s = false;
    }
    if (thumbDownTime > 0) {
      unsigned long held = now - thumbDownTime;
      if (held >= 10000 && !b10s) {
        digitalWrite(LED_BLUE, LED_ON); delay(100); digitalWrite(LED_BLUE, LED_OFF);
        delay(100); digitalWrite(LED_BLUE, LED_ON); delay(100); digitalWrite(LED_BLUE, LED_OFF);
        b10s = true;
      } else if (held >= 5000 && !b5s) {
        digitalWrite(LED_BLUE, LED_ON); delay(200); digitalWrite(LED_BLUE, LED_OFF);
        b5s = true;
      }
    }
  }
  else if (thumbDownTime > 0) {
    unsigned long holdTime = now - thumbDownTime;
    if (holdTime > 30 && !thumbWasInteracted) {
        if (holdTime >= 10000) {
          wifiActive = !wifiActive;
          if(wifiActive) {
            WiFi.begin(ssid, password);
            ArduinoOTA.begin();
            ArduinoOTA.onEnd([]() { wifiActive = false; });
          } else {
            WiFi.disconnect();
          }
        }
        else if (holdTime >= 5000) {
          autoCalEnabled = !autoCalEnabled;
          sendPacket(CMD_CALIBRATE, 0x01, autoCalEnabled ? 0x01 : 0x00);
          preferences.putBool("autocal", autoCalEnabled); // Save to ESP32 memory
        }
        else if (holdTime < 500) {
          sendPacket(CMD_CALIBRATE, 0x02); // Manual NUC
        }
    }
    thumbDownTime = 0;
    thumbActionCooldown = now;
  }
}
